page {
  --color-primary: #EF476F;
  --color-secondary: #FFD166;
  --color-accent: #06D6A0;
  --color-brand-green: #5CB85C;
  --color-brand-teal: #3AAFA9;
  --color-bg: #FFF8F0;
  --color-card: #FFFFFF;
  --color-text: #333333;
  --color-text-light: #888888;
  --color-border: #F0E6DA;
  --radius-lg: 24rpx;
  --radius-md: 16rpx;
  --radius-sm: 8rpx;
  --shadow-card: 0 4rpx 20rpx rgba(0,0,0,0.06);

  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* ====== 九豆米 Brand Logo ====== */
.brand-logo {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 108rpx;
  height: 108rpx;
}

.logo-bg-circle {
  position: absolute;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 45% 40%, rgba(255,241,184,0.9), rgba(255,209,102,0.25) 70%, transparent 100%);
  z-index: 0;
}

.logo-beans {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  width: 88rpx;
  height: 88rpx;
  gap: 6rpx;
  align-content: center;
  justify-items: center;
  align-items: center;
}

.logo-shape {
  width: 22rpx;
  height: 28rpx;
}

.bean {
  width: 22rpx;
  height: 28rpx;
  border-radius: 48% 52% 38% 62% / 52% 45% 55% 48%;
}

.bean-green {
  background: linear-gradient(135deg, #6abf6e, #4a9e4e);
  box-shadow: inset -2rpx -2rpx 4rpx rgba(0,0,0,0.1), inset 2rpx 2rpx 4rpx rgba(255,255,255,0.3);
}

.bean-teal {
  background: linear-gradient(135deg, #4db8b0, #2d9d95);
  box-shadow: inset -2rpx -2rpx 4rpx rgba(0,0,0,0.1), inset 2rpx 2rpx 4rpx rgba(255,255,255,0.25);
}

.rice-grain {
  width: 16rpx;
  height: 32rpx;
  border-radius: 50% / 65%;
  background: linear-gradient(180deg, #f5f0e8, #e8dcc8);
  box-shadow: inset -2rpx 0 4rpx rgba(0,0,0,0.06), inset 2rpx 0 4rpx rgba(255,255,255,0.5);
}

.bean-center {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%, #ffe680, #ffc107);
  box-shadow: 0 4rpx 16rpx rgba(255,193,7,0.5), inset -2rpx -2rpx 6rpx rgba(0,0,0,0.08), inset 2rpx 2rpx 6rpx rgba(255,255,255,0.4);
  animation: beanPulse 3s ease-in-out infinite;
}

@keyframes beanPulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 16rpx rgba(255,193,7,0.5), inset -2rpx -2rpx 6rpx rgba(0,0,0,0.08), inset 2rpx 2rpx 6rpx rgba(255,255,255,0.4);
  }
  50% {
    transform: scale(1.12);
    box-shadow: 0 8rpx 32rpx rgba(255,193,7,0.7), inset -2rpx -2rpx 6rpx rgba(0,0,0,0.08), inset 2rpx 2rpx 6rpx rgba(255,255,255,0.4);
  }
}

.logo-text-group {
  display: flex;
  flex-direction: column;
}

.logo-text-cn {
  font-size: 34rpx;
  font-weight: 850;
  color: #2a2a2a;
  letter-spacing: 4rpx;
  line-height: 1.15;
  text-shadow: 0 2rpx 0 rgba(255,255,255,0.5);
}

.logo-text-en {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--color-text-light);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* Shared card style */
.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: var(--color-primary);
  background: rgba(239, 71, 111, 0.08);
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.tag-green {
  color: var(--color-accent);
  background: rgba(6, 214, 160, 0.08);
}

.tag-yellow {
  color: #D4A017;
  background: rgba(255, 209, 102, 0.2);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
