.player-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A1A2E 0%, #2D2D3F 100%);
  padding: 48rpx 0 0;
  display: flex;
  flex-direction: column;
}

/* Top Bar */
.player-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx 12rpx;
}

.player-logo-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.player-top-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.voice-gear-btn {
  font-size: 36rpx;
  color: rgba(255,255,255,0.6);
  padding: 8rpx;
}

.player-logo-icon {
  font-size: 36rpx;
}

.player-logo-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 3rpx;
}

/* Now Playing */
.now-playing {
  text-align: center;
  padding: 16rpx 32rpx 20rpx;
}

.now-type {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
  margin-bottom: 14rpx;
  display: block;
}

.now-art {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  box-shadow: 0 12rpx 36rpx rgba(0,0,0,0.3);
}

.art-song {
  background: linear-gradient(135deg, #EF476F, #F5958E);
}

.art-icon {
  font-size: 64rpx;
}

.now-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 4rpx;
}

.now-title-zh {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  margin-bottom: 8rpx;
}

.now-source {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  font-style: italic;
  display: block;
}

.now-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #FFD166;
  animation: pulse 1.2s infinite;
}

.status-dot.paused {
  animation: none;
  opacity: 0.3;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.5); }
}

.status-text {
  font-size: 26rpx;
  color: #FFD166;
  font-weight: 600;
}

/* Progress */
.progress-area {
  padding: 0 32rpx;
  margin-bottom: 8rpx;
}

.progress-track {
  height: 6rpx;
  background: rgba(255,255,255,0.12);
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.progress-fill {
  height: 100%;
  background: #FFD166;
  border-radius: 3rpx;
  transition: width 0.3s;
}

.progress-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  text-align: center;
  display: block;
}

/* Controls */
.controls-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 36rpx;
  padding: 16rpx 32rpx 24rpx;
}

.ctrl-btn {
  font-size: 40rpx;
  opacity: 0.7;
}

.ctrl-btn.ctrl-active {
  opacity: 1;
}

.main-play-btn {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #FFD166;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 32rpx rgba(255,209,102,0.4);
}

.main-play-icon {
  font-size: 44rpx;
  margin-left: 4rpx;
}

/* Playlist */
.playlist-section {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 0 24rpx 24rpx;
}

.playlist-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx 14rpx;
}

.playlist-title {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.6);
}

.playlist-count {
  font-size: 24rpx;
  color: rgba(255,255,255,0.3);
}

.playlist-scroll {
  flex: 1;
  min-height: 0;
}

.pl-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
}

.pl-item.pl-current {
  background: rgba(255,255,255,0.1);
}

.pl-index {
  width: 48rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.3);
  flex-shrink: 0;
}

.pl-current .pl-index {
  color: #FFD166;
}

.pl-played .pl-index {
  color: #06D6A0;
}

.pl-type-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.pl-info {
  flex: 1;
  min-width: 0;
}

.pl-name {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pl-current .pl-name {
  color: #fff;
}

.pl-type-label {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-top: 4rpx;
}

.label-song {
  color: #EF476F;
  background: rgba(239,71,111,0.15);
}


.pl-dur {
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
  flex-shrink: 0;
}

/* Voice Settings Panel */
.voice-panel {
  display: none;
  margin: 0 24rpx 20rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.voice-panel.voice-show {
  display: block;
}

.voice-panel-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 20rpx;
  font-weight: 600;
}

.voice-field {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.voice-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  width: 80rpx;
  flex-shrink: 0;
}

.voice-picker {
  flex: 1;
}

.voice-picker-view {
  background: rgba(255,255,255,0.08);
  border-radius: 12rpx;
  padding: 10rpx 16rpx;
  font-size: 24rpx;
  color: #fff;
}

.voice-slider {
  flex: 1;
}

.voice-val {
  font-size: 24rpx;
  color: #FFD166;
  width: 64rpx;
  text-align: right;
  flex-shrink: 0;
}
